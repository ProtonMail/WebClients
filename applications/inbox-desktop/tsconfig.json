{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "sourceMap": true,
        "outDir": "dist",
        "lib": ["WebWorker", "DOM", "DOM.Iterable", "ESNext"],
        "types": ["webpack-env", "global-types-monorepo", "jest"]
    },
    "ts-node": {
        "compilerOptions": {
            "module": "commonjs",
            "target": "esnext",
            "esModuleInterop": true
        },
        "ignore": ["node_modules/(?!@proton)"]
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
