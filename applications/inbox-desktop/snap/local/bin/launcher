#!/usr/bin/env bash

COMMON_OPTS="--no-sandbox --disable-seccomp-filter-sandbox"
WAYLAND_FEATURES="--enable-features=WaylandWindowDecorations,WebRTCPipeWireCapturer"

# Check if wayland socket is reachable inside the snap
WAYLAND_SOCK="${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY:-wayland-0}"

if [ "$XDG_SESSION_TYPE" = "wayland" ] && [ -S "$WAYLAND_SOCK" ]; then
    exec "$SNAP/usr/bin/proton-mail" $COMMON_OPTS $WAYLAND_FEATURES "$@"
else
    exec "$SNAP/usr/bin/proton-mail" $COMMON_OPTS --ozone-platform=x11 "$@"
fi
