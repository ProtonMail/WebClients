{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["WebWorker", "DOM", "DOM.Iterable", "ESNext", "DOM.AsyncIterable"],
        "types": ["@proton/types", "global-types-monorepo", "webpack-env", "jest", "chrome", "./globals.d.ts"]
    },
    "ts-node": {
        "compilerOptions": {
            "module": "commonjs",
            "target": "esnext",
            "esModuleInterop": true
