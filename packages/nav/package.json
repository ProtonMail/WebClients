{
    "name": "@proton/nav",
    "description": "Shared navigation definition builder",
    "type": "module",
    "exports": {
        "./*": "./src/*.ts"
    },
    "main": "./src/index.ts",
    "scripts": {
        "check-types": "tsc",
        "lint": "eslint --quiet",
        "test": "TZ=UTC vitest",
        "test:ci": "yarn test --coverage --run",
        "test:ui": "yarn test --ui",
        "test:watch": "yarn test --watch"
    },
    "dependencies": {
        "@proton/icons": "workspace:^",
        "@proton/shared": "workspace:^",
        "@proton/testing": "workspace:^",
        "@proton/utils": "workspace:^"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@vitest/coverage-v8": "3.2.4",
        "@vitest/ui": "3.2.4",
        "eslint": "^9.39.2",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "ts-jest": "^29.4.6",
        "typescript": "^6.0.2",
        "vitest": "^3.2.4"
    }
}
